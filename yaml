# DAG ID format: {dataset}_{table_name}_table_management
# table_ref: pcb-{env}-landing.<dataset>.<TABLE_NAME>
# scripts: paths relative to DAGs folder, ordered V1, V2, V3...
#   - SQL scripts: .sql files (e.g., V1__CREATE_TABLE.sql)
#   - YAML configs: .yaml files with content-based routing (e.g., V5__CLUSTER_BY_ID.yaml)
#     * clustering_fields -> ClusteringProcessor
#     * partition_field -> PartitioningHandler (future)
#     * transformations -> SchemaEvolutionHandler (future)

# =============================================================================
# Standard template (uncomment and replace placeholders before adding new table)
# =============================================================================
# {dataset}_{table_name}_table_management:
#   default_args:
#     owner: "team-centaurs"
#     capability: "Data Platform"
#     sub_capability: "NV"
#     business_impact: "NA"
#     customer_impact: "NA"
#     severity: "P3"
#   tags:
#     - "team-centaurs"
#     - "bigquery-table-management"
#   table_ref: pcb-{env}-landing.<dataset>.<TABLE_NAME>
#   scripts:
#     - bigquery_table_management/schemas/<dataset>/<table>/V1__CREATE_TABLE_<TABLE>.sql
#     - bigquery_table_management/schemas/<dataset>/<table>/V2__ALTER_ADD_COLUMN.sql
#     - bigquery_table_management/schemas/<dataset>/<table>/V3__CLUSTER_BY_ID.yaml
#     - bigquery_table_management/schemas/<dataset>/<table>/V4__DROP_TABLE_<TABLE>.sql

